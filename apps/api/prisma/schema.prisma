generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lote {
  id                  String              @id @default(uuid())
  codigo              String              @unique
  dataEntrada         DateTime
  cabecas             Int
  pesoMedioEntradaKg  Float
  pesoIdealAbateKg    Float
  custoAquisicaoTotal Decimal             @db.Decimal(12, 2)
  freteTotal          Decimal             @db.Decimal(12, 2)
  status              String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  animais             Animal[]
  pesagens            Pesagem[]
  tratos              TratoDiario[]
  custos              CustoOperacional[]
  tratamentos         TratamentoSanitario[]
  vendas              VendaEmbarque[]
}

model Animal {
  id            String   @id @default(uuid())
  loteId        String
  identificacao String   @unique
  dataEntrada   DateTime
  pesoEntradaKg Float
  status        String
  lote          Lote     @relation(fields: [loteId], references: [id])
  pesagens      Pesagem[]
  tratamentos   TratamentoSanitario[]
}

model Pesagem {
  id         String   @id @default(uuid())
  loteId     String
  animalId   String?
  dataPesagem DateTime
  pesoKg     Float
  lote       Lote     @relation(fields: [loteId], references: [id])
  animal     Animal?  @relation(fields: [animalId], references: [id])
}

model Insumo {
  id         String             @id @default(uuid())
  nome       String
  categoria  String
  estoqueKg  Float
  pontoReposicaoKg Float
  tratos     TratoDiario[]
  movimentos MovimentoEstoque[]
}

model TratoDiario {
  id          String   @id @default(uuid())
  loteId      String
  insumoId    String
  data        DateTime
  quantidadeKg Float
  lote        Lote     @relation(fields: [loteId], references: [id])
  insumo      Insumo   @relation(fields: [insumoId], references: [id])
}

model MovimentoEstoque {
  id          String   @id @default(uuid())
  insumoId    String
  tipo        String
  data        DateTime
  quantidadeKg Float
  custoUnitario Decimal @db.Decimal(10, 2)
  insumo      Insumo   @relation(fields: [insumoId], references: [id])
}

model TratamentoSanitario {
  id            String   @id @default(uuid())
  loteId        String?
  animalId      String?
  medicamento   String
  dataAplicacao DateTime
  diasCarencia  Int
  lote          Lote?    @relation(fields: [loteId], references: [id])
  animal        Animal?  @relation(fields: [animalId], references: [id])
}

model CotacaoArroba {
  id        String   @id @default(uuid())
  data      DateTime
  regiao    String
  valor     Decimal  @db.Decimal(10, 2)
  fonte     String
  usuarioId String
}

model CustoOperacional {
  id        String   @id @default(uuid())
  loteId    String
  data      DateTime
  valor     Decimal  @db.Decimal(12, 2)
  tipo      String
  descricao String
  lote      Lote     @relation(fields: [loteId], references: [id])
}

model VendaEmbarque {
  id               String   @id @default(uuid())
  loteId           String
  dataVenda        DateTime
  frigorifico      String
  pesoTotalKg      Float
  precoArroba      Decimal  @db.Decimal(10, 2)
  receitaTotal     Decimal  @db.Decimal(12, 2)
  descontosTotal   Decimal  @db.Decimal(12, 2)
  lote             Lote     @relation(fields: [loteId], references: [id])
}

model EventoSync {
  id         String   @id @default(uuid())
  cursor     Int      @unique @default(autoincrement())
  eventId    String
  deviceId   String
  sequence   Int
  type       String
  loteId     String?
  animalId   String?
  payload    Json
  occurredAt DateTime
  receivedAt DateTime @default(now())
  @@unique([deviceId, eventId])
}
